# Copy file này thành `.env` ở cùng thư mục (root repo) rồi điền API key.
#   copy .env.example .env        (Windows CMD)
#   Copy-Item .env.example .env   (PowerShell)
#
# Lấy Gemini API key miễn phí:
#   https://aistudio.google.com/apikey

LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite
LLM_TEMPERATURE=0.2

# Dán key từ Google AI Studio vào đây (KHÔNG commit file .env)
GEMINI_API_KEY=your_gemini_api_key_here

# offline = deterministic benchmark (default)
# live   = always call Gemini
# auto   = live when API key exists, else offline
AGENT_MODE=offline

# Tuỳ chọn: judge model dùng cùng Gemini
# JUDGE_LLM_PROVIDER=gemini
# JUDGE_LLM_MODEL=gemini-3.1-flash-lite

# Compact memory (tuỳ chọn)
# COMPACT_THRESHOLD_TOKENS=800
# COMPACT_KEEP_MESSAGES=6
# PROFILE_CONFIDENCE_THRESHOLD=0.75
# MEMORY_DECAY_HALF_LIFE=30

# Benchmark report output (optional, default: output/benchmark_report.md)
# BENCHMARK_OUTPUT=output/benchmark_report.md
